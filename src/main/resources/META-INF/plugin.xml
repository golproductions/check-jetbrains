<idea-plugin>
    <id>com.golproductions.check</id>
    <name>GOL Check - Anti-Hallucination Layer</name>
    <vendor email="support@golproductions.com" url="https://www.golproductions.com">GOL Productions</vendor>

    <description><![CDATA[
    <b>The anti-hallucination layer.</b><br><br>
    Check stops hallucinated commands, packages, and URLs before they reach your project. Invisible. One round trip to the edge. No AI inside.<br><br>
    <b>No signup.</b> A free key is activated on first use. 120 free checks every day. After that, $0.0068 AUD per check. Credits never expire.<br><br>
    <b>One install.</b> Wires Claude Code, Cursor, Gemini CLI, and any MCP client at once:<br>
    <code>npx @golproductions/check --install</code><br><br>
    <a href="https://www.golproductions.com/check.html">Documentation</a> &middot;
    <a href="https://www.golproductions.com/pricing.html">Pricing</a> &middot;
    <a href="https://www.golproductions.com/blog">Blog</a>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <actions>
        <group id="CheckActions" text="Check" description="GOL Check actions">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <action id="Check.ValidateCommand"
                    class="com.golproductions.check.ValidateCommandAction"
                    text="Validate Command with Check"
                    description="Validate a shell command before running it"
                    icon="AllIcons.Actions.ShieldCheck"/>
            <action id="Check.ValidateSelection"
                    class="com.golproductions.check.ValidateSelectionAction"
                    text="Check Selected Text"
                    description="Validate selected text as a command"
                    icon="AllIcons.Actions.ShieldCheck"/>
        </group>
        <action id="Check.ValidateSelectionContext"
                class="com.golproductions.check.ValidateSelectionAction"
                text="Validate with Check"
                icon="AllIcons.Actions.ShieldCheck">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
                parentId="tools"
                instance="com.golproductions.check.CheckSettingsConfigurable"
                id="com.golproductions.check.settings"
                displayName="GOL Check"/>
        <applicationService
                serviceImplementation="com.golproductions.check.CheckSettings"/>
        <notificationGroup id="GOL Check"
                           displayType="BALLOON"
                           key="notification.group.gol.check"/>
    </extensions>
</idea-plugin>
